# Groq cloud inference (recommended: llama-3.3-70b-versatile)
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GOOGLE_API_KEY=

# --- Ollama model selection ---
# Chat model: used by the Gradio agent for responses.
#   96 GB+ RAM:  qwen3.5:122b   (81 GB on disk)
#   32 GB RAM:   gemma4:31b     (19 GB) or qwen3.6:27b (17 GB)
#   16 GB RAM:   gemma4:latest  (9.6 GB)
#   8 GB RAM:    gemma4:e2b     (7.2 GB) or gemma3:4b
OLLAMA_CHAT_MODEL=gemma4:latest

# Ingest model: used for metadata extraction and summary generation during ingest.
#   Smaller = faster ingest; gemma4:latest (9.6 GB) is a good default.
#   Low-spec: gemma4:e2b (7.2 GB) or gemma3:4b
OLLAMA_INGEST_MODEL=gemma4:latest

# --- MLX ingest (Apple Silicon only — much faster than Ollama for ingest) ---
# Set INGEST_PROVIDER=mlx to use Apple MLX instead of Ollama for summarisation
# and verse extraction. Models are auto-downloaded from HuggingFace on first run.
#   Recommended (speed): mlx-community/Qwen3-4B-4bit          (~2.5 GB)
#   Recommended (accuracy): mlx-community/Qwen3-8B-4bit       (~4.5 GB)
# Install: pip install mlx-lm
INGEST_PROVIDER=ollama_local
MLX_INGEST_MODEL=mlx-community/Qwen3-8B-4bit
