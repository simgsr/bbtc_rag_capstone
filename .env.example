# ── Cloud fallback (optional) ────────────────────────────────────────────────
# Free keys: https://console.groq.com  |  https://aistudio.google.com
GROQ_API_KEY=
GOOGLE_API_KEY=

# ── Chat UI  (Gradio / LangGraph agent) ──────────────────────────────────────
# The "Inference Engine" radio in the UI picks among 4 backends at runtime:
#   1. Ollama local  → OLLAMA_CHAT_MODEL  (see below)
#   2. MLX local     → MLX_CHAT_MODEL     (Apple Silicon, runs via mlx_lm.server)
#   3. Groq cloud    → GROQ_API_KEY
#   4. Gemini cloud  → GOOGLE_API_KEY
#
# Ollama chat model — adjust to your available RAM:
#   96 GB+  →  qwen3.5:122b  (81 GB)
#   32 GB   →  gemma4:31b    (19 GB)
#   16 GB   →  gemma4:latest  (9.6 GB)
#    8 GB   →  gemma4:e2b / gemma3:4b
OLLAMA_CHAT_MODEL=gemma4:latest
OLLAMA_NUM_CTX=32768                          # Ollama context window (default 2048 is too small for ReAct + history)

# MLX chat model — used when "[mlx]" is selected in the Inference Engine radio.
# Boots mlx_lm.server as a subprocess (OpenAI-compatible API). Auto-downloads on first run.
# One model is served at a time — switch by editing this line (restart required).
#   ~128 GB RAM  →  mlx-community/Qwen3-Next-80B-A3B-Instruct-8bit  (~85 GB, MoE 3B-active; highest quality, needs mlx-lm >= 0.27)
#   ~32 GB+ RAM  →  mlx-community/Qwen3-30B-A3B-Instruct-2507-4bit  (~17 GB, MoE 3B-active; default)
#   ~8 GB RAM    →  mlx-community/Qwen3-4B-4bit                     (~2.5 GB)
MLX_CHAT_MODEL=mlx-community/Qwen3-30B-A3B-Instruct-2507-4bit
MLX_SERVER_HOST=127.0.0.1
MLX_SERVER_PORT=8081
MLX_PROMPT_CACHE_SLOTS=4                      # KV-cache slots → reuse system prompt + tool schemas across calls
MLX_PROMPT_CACHE_BYTES=8000000000             # 8 GB KV cache budget

# ── Ingest LLM  (summarisation + verse extraction) ───────────────────────────
# mlx          → Apple Silicon Neural Engine; fast, no Ollama model-swap (default)
# ollama_local → uses OLLAMA_INGEST_MODEL; causes model-swap with BGE-M3, slower
# groq/gemini  → cloud fallback; set the matching API key above
INGEST_PROVIDER=mlx
MLX_INGEST_MODEL=mlx-community/Qwen3-4B-4bit   # auto-downloaded on first run
OLLAMA_INGEST_MODEL=gemma4:latest               # only used when INGEST_PROVIDER=ollama_local

# ── Embeddings  (ChromaDB) ───────────────────────────────────────────────────
# Ollama is NOT needed for embeddings — only for the chat UI (OLLAMA_CHAT_MODEL above).
# EMBED_BACKEND selects the embedder. Switching backends requires a wipe + re-ingest
# (python ingest.py --wipe  &&  python -m src.ingestion.bible.bible_ingest --wipe) so
# stored and query vectors come from the same model.
#   st        → BAAI/bge-m3 via sentence-transformers (PyTorch MPS, fp32) — 1024-dim (default)
#   mlx_bge   → mlx-community/bge-m3-mlx-fp16 (Apple Silicon) — 1024-dim, ~2x faster, ~3 GB RAM
#   mlx_qwen  → mlx-community/Qwen3-Embedding-8B-4bit-DWQ — 4096-dim, higher MTEB, ~6 GB RAM, slower
EMBED_BACKEND=st
# MLX_EMBED_MODEL=mlx-community/bge-m3-mlx-fp16   # override the HF repo for mlx_* backends
# MLX_EMBED_MAX_LEN=1024                          # token cap per chunk for mlx_* backends
