# Groq cloud inference (recommended: llama-3.3-70b-versatile)
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GOOGLE_API_KEY=

# --- Ollama model selection ---
# Chat model: used by the Gradio agent for responses.
#   High-spec  (32 GB+ RAM): qwen3.5:122b
#   Mid-spec   (16 GB RAM):  gemma4:latest  or  llama3.1:8b
#   Low-spec   (8 GB RAM):   gemma3:4b      or  phi4-mini
OLLAMA_CHAT_MODEL=gemma4:latest

# Ingest model: used for metadata extraction and summary generation during ingest.
#   Any model that fits in RAM works; smaller = faster ingest.
#   Recommended: gemma4:latest (9.6 GB) or gemma3:4b (3 GB) for low-spec devices.
OLLAMA_INGEST_MODEL=gemma4:latest
